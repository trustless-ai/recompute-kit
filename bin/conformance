#!/usr/bin/env python3
"""conformance — verify an implementation reproduces the agent-flow GOLDEN VECTORS.

The vectors (`conformance/agent-flow.vectors.json`) are the canonical authority:
public inputs → expected recompute, for each step of the composed flow. "Conformant"
means an implementation reproduces every `expected` from the same `inputs` — NOT that
it matches any one SDK's output. This file is the *reference* recompute (via `cast`); a
language SDK runs the SAME vectors through its own code and compares. CI-gate every SDK,
TS reference included, against these — no trusted implementation in the loop.

(The on-chain 8274 verify is a contract call, identical for every SDK, so it is not a
pure-recompute vector — checked separately via recompute-step 8274/verify.)
"""
import sys, json, subprocess, hashlib
from decimal import Decimal, ROUND_HALF_UP
from pathlib import Path

VEC = Path(__file__).resolve().parent.parent / "conformance" / "agent-flow.vectors.json"


def cast(*a):
    return subprocess.run(["cast", *map(str, a)], capture_output=True, text=True).stdout.strip()


def recompute(v):
    s, i = v["step"], v["inputs"]
    if s == "8004/agent-id":
        # ERC-8004 agentId = bytes32(uint256(registryId)) (live erc-8299.md, PR #1810) — the
        # registry-assigned identity, left-padded. NOT a hash of any name.
        return "0x" + format(int(i["registryId"]), "064x")
    if s == "name/keccak-binding":
        # keccak256(utf8(label)) — a name->handle binding (wyriwe preimage leg), not the agentId.
        return cast("keccak", cast("from-utf8", i["label"]))
    if s == "receiptos/canonicalize":
        # receiptos-c14n-v0 (RAILS/ReceiptOS §2.8): receipt_root = 0x + sha256( C(A(E)) ).
        # A(E) strips the top-level anchor; C = recursive sorted-key / compact / literal-UTF-8
        # (JCS by reference, anchor-strip sole delta). Pure recompute, no cast.
        E = i["evidence"]
        c = json.dumps({k: v for k, v in E.items() if k != "anchor"},
                       ensure_ascii=False, sort_keys=True, separators=(",", ":"))
        return "0x" + hashlib.sha256(c.encode("utf-8")).hexdigest()
    if s == "wyriwe/raw":
        return cast("keccak", i["raw_input_hex"])
    if s == "wyriwe/pipeline":
        return cast("keccak", cast("concat-hex", cast("from-utf8", i["spec_cid"]), i["raw_input_hash"]))
    if s == "scope/binding":
        return cast("keccak", cast("abi-encode", "f(bytes32,uint256)", i["merkleRoot"], i["count"]))
    if s == "8203/settlement-proof":
        # ConsultEscrow release commitment: verdictHash = keccak(abi.encode(jobId, keccak(utf8 resultText))).
        rh = cast("keccak", cast("from-utf8", i["resultText"]))
        return cast("keccak", cast("abi-encode", "f(bytes32,bytes32)", i["jobId"], rh))
    if s == "8301/task-hash":
        inner = cast("keccak", i["prevReplyHashesPacked"])
        enc = cast("abi-encode", "f(uint8,uint256,bytes32,uint256,uint256,bytes32,bytes32)",
                   i["stage"], i["taskSeq"], i["inputHash"], i["timestamp"],
                   i["expiresAt"], inner, i["workflowRunId"])
        return cast("keccak", enc)
    if s == "8275/reputation":
        # canonical INPUT recompute: winRate = gated_wins/(gated_wins+gated_losses), checked vs the
        # ledger's PUBLISHED winRate (primary artifact). The composite score is an impl-defined view,
        # deliberately NOT a conformance value.
        gw, gl = i["commit_gated_wins"], i["commit_gated_losses"]
        # No resolved history -> winRate is UNDEFINED (None), never 0 — fails-closed, per the
        # "incomplete window" doctrine (a gap in evidence must not read as a clean 0.0 record).
        if gw + gl == 0:
            return None
        # Decimal + ROUND_HALF_UP (half-away-from-zero), not Python's built-in round() --
        # round() is banker's rounding (half-to-even) on a float, which diverges from Rust's
        # f64::round() (half-away-from-zero) on any gw/gl ratio landing exactly on a 4th-decimal
        # tie (e.g. gw=1,gl=31 -> 1/32=0.03125 exactly: round()=0.0312, half-away-from-zero=0.0313).
        # This is the golden every SDK reproduces byte-identically, so the convention has to be
        # fixed and language-independent, computed from exact integers, not a bare float round().
        return float((Decimal(gw) / Decimal(gw + gl)).quantize(Decimal("0.0001"), rounding=ROUND_HALF_UP))
    if s == "8281/observation-digest":
        # ERC-8281 §1 (OCP): digest = keccak256(observation) — the opaque commitment record()s
        # on-chain. Canonicalized so all SDKs gate on ONE vector, not each impl's inline golden.
        return cast("keccak", cast("from-utf8", i["observation"]))
    if s == "scope/bond-standing":
        # Layer 3: standing recomputed from public survival(bondId), never asserted.
        return (not i["slashed"]) and (not i["challenged"])
    if s == "scope/value-fidelity":
        # guard 5: resolutionRoot = keccak(abi.encode(leaves)); leaf = keccak(abi.encode(sourceId, option))
        votes = sorted(i["votes"], key=lambda v: int(v[0], 16))   # contract sorts by sourceId asc
        leaves = [cast("keccak", cast("abi-encode", "f(bytes32,uint8)", v[0], v[1])) for v in votes]
        return cast("keccak", cast("abi-encode", "f(bytes32[])", "[" + ",".join(leaves) + "]"))
    if s == "scope/contest-verify":
        # contest() separation: separated = w(a) != w(b), b = a ++ [X]; w = MajorityClassifier
        # plurality (NO_QUORUM on tie-at-max / below-quorum). Expected verdicts come from the
        # merged contract (forge), not from here — this reference reproduces them.
        from collections import Counter
        q, a, x = i["quorumBps"], list(i["aOptions"]), i["xOption"]
        def plur(opts):
            if not opts: return None
            c = Counter(opts); total = len(opts); best = 0; bestC = 0; tie = False
            for o in sorted(c):
                if c[o] > bestC: bestC, best, tie = c[o], o, False
                elif c[o] == bestC and bestC > 0: tie = True
            if tie: return None
            if bestC * 10000 < total * q: return None
            return best
        return plur(a) != plur(a + [x])
    if s == "ens/namehash":
        # EIP-137 namehash, recomputed by RECURSION (node = keccak(parent ‖ keccak(label)),
        # right-to-left) — independent of the recipe's `cast namehash`, so it's a real cross-check.
        node = "0x" + "00" * 32
        for label in reversed(i["name"].split(".")) if i["name"] else []:
            lh = cast("keccak", cast("from-utf8", label))
            node = cast("keccak", "0x" + node[2:] + lh[2:])
        return node
    if s == "8312/cap-conservation":
        # ERC-8312 cap invariant: aggregate <= cap. Recomputable to a SOUND verdict because the
        # Security clause binds confirm/cancel to the reserver (no third party can forge the
        # trajectory). Two layouts, one invariant: StatefulBound (reserved+confirmed, zero-human-loop
        # @ 5530a9c) or a struct/turnover cursor ('aggregate', orbmis/headroom) — both proven vs
        # stateRoot by recompute-step 8312/cap-conservation (literal cap | struct:S:A:C).
        agg = i["aggregate"] if "aggregate" in i else i["reserved"] + i["confirmed"]
        return agg <= i["cap"]
    if s == "8312/budget-substrate":
        # ERC-8312 IBudgetSubstrate — the spec-formalized name for the same cap invariant.
        # bound(id) → (cap, asset); spent(id); remaining(id) → cap - spent. Two checks:
        #   (a) the substrate's reported `remaining` MUST equal cap - spent (no misreport), and
        #   (b) spent <= cap must hold while Active. `spent` here replaces the pre-standard
        # reserved+confirmed (StatefulBound) / aggregate (CursorHeadroom) — same math, spec fields.
        remaining_ok = ("remaining" not in i) or (i["remaining"] == i["cap"] - i["spent"])
        return remaining_ok and i["spent"] <= i["cap"]
    # Composed / node recipes (seam4/envelope-align, receiptos×wyriwe, …) aren't reproducible in
    # this static evaluator — they're verified live via recompute-step. Skip with a note, never crash.
    return "SKIP:live"


def main():
    d = json.load(open(VEC))
    print(f"{d['name']} v{d['version']} — {len(d['vectors'])} vectors")
    print("─" * 56)
    fails = 0; skipped = 0
    # Structural gate: the DECLARED rounding convention (its own content-hash, the way
    # ruleset_version pins a recipe). Conformance is "does your convention hash match",
    # not "did you reproduce whichever ties happen to be in the vector set today."
    rc = d.get("rounding_convention")
    if rc:
        canon = json.dumps(rc["rule"], sort_keys=True, separators=(",", ":"), ensure_ascii=False)
        got = "0x" + hashlib.sha256(canon.encode("utf-8")).hexdigest()
        ok = got == rc["hash"]
        print(f"{'✓' if ok else '✗'} rounding_convention  hash {rc['hash'][:16]}… — {'match' if ok else 'MISMATCH'} (governs {', '.join(rc['governs'])})")
        if not ok:
            print(f"    declared {rc['hash']}\n    got      {got}"); fails += 1
        print("─" * 56)
    for v in d["vectors"]:
        got = recompute(v)
        if isinstance(got, str) and got.startswith("SKIP"):
            print(f"○ {v['id']:<17} {v['step']:<17} — skipped ({got.split(':')[1]} recipe; run via recompute-step)")
            skipped += 1; continue
        exp = v["expected"]
        ok = str(got).lower() == str(exp).lower()
        print(f"{'✓' if ok else '✗'} {v['id']:<17} {v['step']:<17} = {str(exp)[:30]}")
        if not ok:
            print(f"    expected {exp}\n    got      {got}")
            fails += 1
    print("─" * 56)
    total = len(d["vectors"]); reproduced = total - skipped - fails
    print(f"{reproduced} reproduced · {skipped} skipped (live recipes, via recompute-step) · {total} total")
    tail = f" ({skipped} node recipe(s) skipped — checked via recompute-step)" if skipped else ""
    print(("✓ CONFORMANT — all vectors reproduced" + tail) if not fails else f"✗ {fails} vector(s) FAILED{tail}")
    sys.exit(1 if fails else 0)


if __name__ == "__main__":
    main()
