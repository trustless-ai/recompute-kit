#!/usr/bin/env bash
# recompute-step <recipe> <args...>
#
# Recompute a named step of the agent-standards flow from PUBLIC inputs, composing the
# kit's primitives (recompute-commitment / recompute-repo / recompute-onchain). Each
# recipe encodes one step's recompute recipe — the ERC-specific knowledge lives here,
# thin, not in the generic primitives.
#
#   recompute-step list
#   recompute-step wyriwe/pipeline ipfs://Qm... 0x<raw_input_hash> 0x<expected>
#   recompute-step scope/binding   0x<merkleRoot> 4 0x<expected_scopeRoot>
set -euo pipefail
BIN="$(cd "$(dirname "$0")" && pwd)"
recipe="${1:-list}"

case "$recipe" in
  list)
    cat <<'EOF'
recompute-step recipes (start: the two steps we built end-to-end)

  INPUT PROVENANCE — ERC-8299 / WYRIWE (Step 3, behavioral)
    wyriwe/raw       <raw_input_hex> <expected>
                     raw_input_hash = keccak256(raw_user_input)
    wyriwe/pipeline  <spec_cid> <raw_input_hash> <expected>
                     sanitization_pipeline_hash = keccak256(utf8(cid) ‖ raw_input_hash)

  OBSERVATION COMPLETENESS — scope-contestation
    scope/binding    <merkleRoot> <count> <expected_scopeRoot>
                     scopeRoot = keccak256(abi.encode(root, N))   (Guarantee 4 — truncation-resistant)
    scope/suite      [ref]
                     run the contest() four-guard reference suite (TMerlini/hack-ens-recovery)

  IDENTITY — ERC-8004 (Step 1)
    8004/agent-id    <agentRef> <expected_agentId>
                     agentId = keccak256(utf8(agentRef))          (ERC-8299 §Step3 derivation)

  ELIGIBILITY — ReceiptOS (Step 5)
    receiptos/receipt-hash  <receipt.json>
                     receipt_sha256 = sha256(decision_sha256 ‖ prev)   (receiptos-mvp hash-chain)

  REPUTATION — ERC-8275 (Step 7)
    8275/reputation  [ledger_url]
                     winRate*min(closedOutcomes,volumeCap)/volumeCap  (live api.babyblueviper.com/ledger)

  VERIFY — ERC-8274 / 8263 (Step 4)
    8274/verify      <rpc> <block> <inputHash> <outputHash> <metadata> <proof>
                     WyriweProofVerifier(0xd8a0…18a09).verify(...) == true  (canonical deployed verifier)

  DISPATCH — ERC-8301 (Step 2)
    8301/task-hash   <stage> <taskSeq> <inputHash> <timestamp> <expiresAt> <workflowRunId> <expected> [prevReplyHashesPacked]
                     taskHash = keccak256(abi.encode(uint8 stage, uint256 taskSeq, bytes32 inputHash,
                       uint256 timestamp, uint256 expiresAt, keccak256(abi.encodePacked(prevReplyHashes)),
                       bytes32 workflowRunId))   (ERC-8301; prevReplyHashesPacked empty for the initial task)

  PRECEDENCE — ERC-8263 anchor (value-fidelity type-2)
    8263/precedence  <digest> <ots_proof_url_or_file> [outcome_timestamp]
                     OTS digest → Bitcoin block → merkleroot cross-checked off a public
                     explorer (no node, no trust); strict block_time < outcome if given

  DEFENSE STANDING — Layer 3 completeness bond (damonzwicker/scope-contestation)
    scope/bond-standing  <rpc> <bond_addr> <bondId> [as_of]
                     recompute(survival(bondId)) → standing = (not slashed ∧ not challenged);
                     bounty=amount, age=as_of−bondStart (Lindy strength). "which agent is good?"
                     recomputed from public bond state, not asserted.

  — 7 flow steps + value-fidelity precedence + Layer-3 standing, recomputable end-to-end —
EOF
    ;;

  8004/agent-id)
    ref="${2:?need agentRef}"; exp="${3:?need expected agentId}"
    command -v cast >/dev/null || { echo "need foundry (cast)" >&2; exit 69; }
    echo "→ 8004/agent-id: agentId = keccak256(utf8(\"$ref\"))"
    exec "$BIN/recompute-commitment" keccak "$exp" "$(cast from-utf8 "$ref")" ;;

  receiptos/receipt-hash)
    f="${2:?need a receipt .json file}"
    python3 - "$f" <<'PY'
import sys, json, hashlib
r = json.load(open(sys.argv[1]))
canon = lambda o: json.dumps(o, ensure_ascii=False, sort_keys=True, separators=(',', ':')).encode()
sha = lambda b: hashlib.sha256(b).hexdigest()
unsigned = {k: v for k, v in r.items() if k not in ('hashes', 'signature')}
decision = sha(canon(unsigned))
prev = (r.get('hashes') or {}).get('prev_receipt_sha256')
receipt = sha(f"{decision}|{prev or ''}".encode())
exp = (r.get('hashes') or {}).get('receipt_sha256')
print("→ receiptos/receipt-hash: receipt_sha256 = sha256(decision_sha256 ‖ prev)  [receiptos-mvp]")
print("─" * 45)
print("decision_sha256 (recomputed):", decision)
print("receipt_sha256  (recomputed):", receipt)
print("receipt_sha256  (published) :", exp)
ok = receipt == exp
print("✓ RECOMPUTED — receipt hash matches the published chain" if ok
      else "✗ MISMATCH — recomputed receipt hash ≠ published")
sys.exit(0 if ok else 1)
PY
    ;;

  8275/reputation)
    url="${2:-https://api.babyblueviper.com/ledger}"
    python3 - "$url" <<'PY'
import sys, json, urllib.request
d = json.load(urllib.request.urlopen(sys.argv[1], timeout=15))
r = d['reputation_axis']; dv = r['derivation']; inp = r['inputs']
wins, losses, closed = dv['commit_gated_wins'], dv['commit_gated_losses'], dv['commit_gated_closed']
cap = inp['volumeCap']
winRate = wins / (wins + losses)
rep = winRate * min(closed, cap) / cap
pub_rep, pub_wr = r['reputation'], inp['winRate']
print("→ 8275/reputation: winRate*min(closedOutcomes,volumeCap)/volumeCap  [ERC-8275 axis, live /ledger]")
print("─" * 45)
print(f"from published derivation: wins={wins} losses={losses} closed={closed} cap={cap}")
print(f"winRate    recomputed {winRate:.4f}  vs published {pub_wr}")
print(f"reputation recomputed {rep:.4f}  vs published {pub_rep}")
ok = abs(winRate - pub_wr) < 5e-4 and abs(rep - pub_rep) < 5e-4
print("✓ RECOMPUTED — reputation recomputes from its published counts" if ok
      else "✗ MISMATCH — published reputation ≠ recomputed")
print("  (deeper tier: re-derive wins/losses/closed by verifying each entry's schnorr sig + 8263 anchor)")
sys.exit(0 if ok else 1)
PY
    ;;

  wyriwe/raw)
    raw="${2:?need raw_input hex}"; exp="${3:?need expected raw_input_hash}"
    echo "→ wyriwe/raw: raw_input_hash = keccak256(raw_user_input)"
    exec "$BIN/recompute-commitment" keccak "$exp" "$raw" ;;

  wyriwe/pipeline)
    cid="${2:?need sanitization_spec_cid}"; rawhash="${3:?need raw_input_hash}"; exp="${4:?need expected}"
    command -v cast >/dev/null || { echo "need foundry (cast)" >&2; exit 69; }
    cidhex="$(cast from-utf8 "$cid")"
    packed="$(cast concat-hex "$cidhex" "$rawhash")"
    echo "→ wyriwe/pipeline: keccak256( utf8(\"$cid\") ‖ $rawhash )"
    exec "$BIN/recompute-commitment" keccak "$exp" "$packed" ;;

  scope/binding)
    root="${2:?need merkleRoot}"; n="${3:?need count}"; exp="${4:?need expected scopeRoot}"
    echo "→ scope/binding: bind(root,N) = keccak256(abi.encode(root, $n))"
    exec "$BIN/recompute-commitment" abi-keccak "$exp" "f(bytes32,uint256)" "$root" "$n" ;;

  scope/suite)
    ref="${2:-main}"
    exec "$BIN/recompute-repo" https://github.com/TMerlini/hack-ens-recovery "$ref" \
      "cd scope-contestation-demo/contracts && (ls lib/forge-std >/dev/null 2>&1 || git clone -q --depth 1 https://github.com/foundry-rs/forge-std lib/forge-std) && forge test" ;;

  8274/verify)
    rpc="${2:?need rpc-url (mainnet)}"; block="${3:?need block (pin, or latest)}"
    inh="${4:?need inputHash}"; outh="${5:?need outputHash}"
    meta="${6:?need metadata bytes (0x…)}"; proof="${7:?need proof bytes (0x…)}"
    echo "→ 8274/verify: WyriweProofVerifier(0xd8a0…18a09).verify(inputHash,outputHash,metadata,proof) == true"
    exec "$BIN/recompute-onchain" "$rpc" "$block" 0xd8a09d830b27697e1b24e8c9800e562d20318a09 \
      "verify(bytes32,bytes32,bytes,bytes)(bool)" true "$inh" "$outh" "$meta" "$proof" ;;

  8301/task-hash)
    stage="${2:?need stage}"; seq="${3:?need taskSeq}"; inh="${4:?need inputHash}"
    ts="${5:?need timestamp}"; exp_at="${6:?need expiresAt}"; run="${7:?need workflowRunId}"
    expected="${8:?need expected taskHash}"; prev="${9:-0x}"
    command -v cast >/dev/null || { echo "need foundry (cast)" >&2; exit 69; }
    # inner: keccak256(abi.encodePacked(prevReplyHashes)) — packed = concat of the bytes32 elems (0x = empty / initial task)
    inner="$(cast keccak "$prev")"
    echo "→ 8301/task-hash: keccak256(abi.encode(stage,taskSeq,inputHash,timestamp,expiresAt,keccak(prevReplyHashes),workflowRunId))"
    echo "  prevReplyHashes hash = $inner"
    exec "$BIN/recompute-commitment" abi-keccak "$expected" \
      "f(uint8,uint256,bytes32,uint256,uint256,bytes32,bytes32)" \
      "$stage" "$seq" "$inh" "$ts" "$exp_at" "$inner" "$run" ;;

  8263/precedence)
    digest="${2:?need OTS digest (event_id stamped)}"; proof="${3:?need .ots proof url or file}"
    outcome="${4:-}"
    python3 - "$digest" "$proof" "$outcome" <<'PY'
import sys, os, re, json, shutil, subprocess, tempfile, urllib.request
digest, proof, outcome = sys.argv[1], sys.argv[2], (sys.argv[3] or None)
ots = shutil.which("ots") or os.path.expanduser("~/Library/Python/3.14/bin/ots")
if not os.path.exists(ots) and not shutil.which("ots"):
    sys.exit("need the OpenTimestamps client: pip install opentimestamps-client")
# resolve proof → local file
pf = proof
if proof.startswith("http"):
    pf = tempfile.mktemp(suffix=".ots")
    urllib.request.urlretrieve(proof, pf)
# OTS resolves the proof to a Bitcoin block + merkleroot (no local node)
r = subprocess.run([ots, "--no-bitcoin", "verify", "-d", digest, pf], capture_output=True, text=True)
m = re.search(r"Bitcoin block (\d+) has merkleroot ([0-9a-fA-F]+)", r.stdout + r.stderr)
if not m:
    print("✗ OTS proof did not resolve to a Bitcoin block:"); print((r.stdout + r.stderr)[-300:]); sys.exit(1)
block, ots_root = int(m.group(1)), m.group(2).lower()
# cross-check the merkleroot off a public explorer (no node, no trust in the ledger)
h = urllib.request.urlopen(f"https://blockstream.info/api/block-height/{block}", timeout=15).read().decode()
b = json.load(urllib.request.urlopen(f"https://blockstream.info/api/block/{h}", timeout=15))
exp_root, block_time = b["merkle_root"].lower(), b["timestamp"]
print(f"→ 8263/precedence: OTS digest → Bitcoin block {block}, merkleroot cross-checked off blockstream")
print("─" * 56)
print(f"OTS merkleroot:      {ots_root}")
print(f"explorer merkleroot: {exp_root}  (block {block})")
print(f"block_time:          {block_time}")
if ots_root != exp_root:
    print("✗ MISMATCH — OTS merkleroot ≠ explorer merkleroot (anchor not confirmed)"); sys.exit(1)
if outcome:
    strict = block_time < int(outcome)
    print(f"strict precedence:   {block_time} < {outcome}  →  {strict}")
    if not strict:
        print("✗ PRECEDENCE FAILS — anchor not strictly before the outcome"); sys.exit(1)
    print("✓ RECOMPUTED — anchor Bitcoin-confirmed AND strictly precedes the outcome")
else:
    print("✓ RECOMPUTED — anchor Bitcoin-confirmed (merkleroot matches explorer); pass an outcome_ts for the strict < check")
PY
    ;;

  scope/bond-standing)
    # Layer 3 (damonzwicker/scope-contestation, ICompletenessBond): recompute an agent's
    # completeness STANDING from the public bond state — survival(bondId) — never from an
    # asserted score. standing = (not slashed) and (not challenged): the bond was never
    # falsified by a material-omission proof. bounty + age are the Lindy strength signal.
    rpc="${2:?need rpc-url}"; bond="${3:?need bond contract addr}"
    bondId="${4:?need bondId (bytes32)}"; asof="${5:-}"
    python3 - "$rpc" "$bond" "$bondId" "$asof" <<'PY'
import sys, subprocess, time
rpc, bond, bondId, asof = sys.argv[1], sys.argv[2], sys.argv[3], (sys.argv[4] or None)
# exact ABI from ICompletenessBond.sol survival(bytes32):
sig = "survival(bytes32)(uint256,uint64,uint64,uint64,bool,bool)"
r = subprocess.run(["cast","call",bond,sig,bondId,"--rpc-url",rpc],
                   capture_output=True, text=True)
if r.returncode != 0:
    print("✗ survival() call failed:", (r.stderr or r.stdout).strip()[:200]); sys.exit(1)
v = r.stdout.split()
amount, bondStart, termEnd, resolvedAt = int(v[0]), int(v[1]), int(v[2]), int(v[3])
slashed, challenged = v[4].lower()=="true", v[5].lower()=="true"
# the recompute (Point: standing-as-survival, not asserted):
standing = (not slashed) and (not challenged)
state = "live" if resolvedAt==0 else ("survived (reclaimed)" if not slashed else "slashed")
now = int(asof) if asof else int(time.time())
age = now - bondStart
print(f"→ scope/bond-standing: recompute(survival({bondId[:12]}…)) — Layer 3 completeness bond")
print("─"*58)
print(f"bounty (amount):     {amount}")
print(f"age (now−bondStart): {age}s  (termEnd in {termEnd-now}s)")
print(f"state:               {state}")
print(f"slashed / challenged: {slashed} / {challenged}")
print(f"STANDING:            {standing}")
print("✓ STANDING — recomputed from public bond state: unslashed, unchallenged "
      "(bounty×age = Lindy strength)" if standing else
      "✗ NOT STANDING — bond falsified (slashed or successfully challenged)")
sys.exit(0 if standing else 1)
PY
    ;;

  *)
    echo "unknown recipe: $recipe  (try: recompute-step list)" >&2; exit 64 ;;
esac
