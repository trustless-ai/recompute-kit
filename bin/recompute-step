#!/usr/bin/env bash
# recompute-step <recipe> <args...>
#
# Recompute a named step of the agent-standards flow from PUBLIC inputs, composing the
# kit's primitives (recompute-commitment / recompute-repo / recompute-onchain). Each
# recipe encodes one step's recompute recipe — the ERC-specific knowledge lives here,
# thin, not in the generic primitives.
#
#   recompute-step list
#   recompute-step wyriwe/pipeline ipfs://Qm... 0x<raw_input_hash> 0x<expected>
#   recompute-step scope/binding   0x<merkleRoot> 4 0x<expected_scopeRoot>
#
# TRI-STATE EXIT CONVENTION ("couldn't check is its own verdict, never a pass"):
#   0  = verified-good   (recompute ran, verdict holds)
#   1  = verified-bad    (recompute ran, verdict is a determinate mismatch/fail)
#   2  = UNVERIFIABLE    (recompute could NOT run: fetch/RPC/tool/timeout/pending data)
#   64 = usage error
# Consumers gate on this: unverifiable -> fail-closed (defer/deny) for irreversible
# actions, fail-annotate for reversible ones. Never treat 2 as a pass.
set -euo pipefail
BIN="$(cd "$(dirname "$0")" && pwd)"
recipe="${1:-list}"

case "$recipe" in
  list)
    cat <<'EOF'
recompute-step recipes (start: the two steps we built end-to-end)

  INPUT PROVENANCE — ERC-8299 / WYRIWE (Step 3, behavioral)
    wyriwe/raw       <raw_input_hex> <expected>
                     raw_input_hash = keccak256(raw_user_input)
    wyriwe/pipeline  <spec_cid> <raw_input_hash> <expected>
                     sanitization_pipeline_hash = keccak256(utf8(cid) ‖ raw_input_hash)

  OBSERVATION COMPLETENESS — scope-contestation
    scope/binding    <merkleRoot> <count> <expected_scopeRoot>
                     scopeRoot = keccak256(abi.encode(root, N))   (Guarantee 4 — truncation-resistant)
    scope/value-fidelity  <committed_root|-> <sourceId>:<opt> ...
                     guard 5 (type-2): resolutionRoot = keccak256(abi.encode(leaves)),
                     leaf = keccak256(abi.encode(sourceId, option)); recompute a's values vs committed
    scope/value-fidelity-onchain  <rpc> <reader> <blockPin> <sourceId>:<opt> ...
                     guard 5 (type-1): reader.valueAt(sourceId, blockPin) == claimed, per source
    scope/contest-verify  <quorumBps> <a-options-csv> <X-option> [expected_separated]
                     the four-guard + guard-7 contest() SEPARATION verdict: separated = w(a) != w(b),
                     b = a ++ [X], via MajorityClassifier plurality/quorum. The materiality the
                     completeness bond slashes on. Guards 5/7 compose value-fidelity[-onchain];
                     a type-2 contest's guard-7 defers → UNVERIFIABLE (the tri-state span).
    scope/suite      [ref]
                     run the contest() four-guard reference suite (TMerlini/hack-ens-recovery)

  IDENTITY — ERC-8004 (Step 1)
    8004/agent-id    <registryId> [expected_bytes32]
                     agentId = bytes32(uint256(registryId)) — the ERC-8004 registry-assigned id,
                     left-padded (live erc-8299.md, PR #1810). NOT a hash of any name.
    name/keccak-binding  <label> <expected_digest>
                     keccak256(utf8(label)) — a name→handle binding (wyriwe preimage leg). NOT the
                     8004 agentId (that's the registry id) and NOT an ENS namehash.
    ens/namehash     <name> [expected_node]
                     EIP-137 node = keccak(parent ‖ keccak(label)) over labels — the id ENS
                     resolves. DISTINCT from 8004/agent-id's flat keccak(utf8(name)); use this
                     when the agent identity is the ENS node, not a flat label commitment.

  ELIGIBILITY — ReceiptOS (Step 5)
    receiptos/receipt-hash  <receipt.json>
                     receipt_sha256 = sha256(decision_sha256 ‖ prev)   (receiptos-mvp hash-chain)

  REPUTATION — ERC-8275 (Step 7)
    8275/reputation  [ledger_url]
                     Verdicts that the recomputable INPUTS reproduce (winRate = gated_wins/(gated_wins
                     +gated_losses), closedOutcomes) vs the ledger's published values; the composite
                     reputation = f(inputs) is a VIEW, never a pass/fail (8275 specifies the shape as
                     RECOMMENDED — no canonical score). attestationCount / counterpartyDiversity
                     recompute per-entry via verify-proof (schnorr + artifact_hash).

  VERIFY — ERC-8274 / 8263 (Step 4)
    8274/verify      <rpc> <block> <inputHash> <outputHash> <metadata> <proof>
                     WyriweProofVerifier(0xd8a0…18a09).verify(...) == true  (canonical deployed verifier)

  DISPATCH — ERC-8301 (Step 2)
    8301/task-hash   <stage> <taskSeq> <inputHash> <timestamp> <expiresAt> <workflowRunId> <expected> [prevReplyHashesPacked]
                     taskHash = keccak256(abi.encode(uint8 stage, uint256 taskSeq, bytes32 inputHash,
                       uint256 timestamp, uint256 expiresAt, keccak256(abi.encodePacked(prevReplyHashes)),
                       bytes32 workflowRunId))   (prevReplyHashesPacked empty for the initial task)
                     ✓ ANCHORED: struct order + types confirmed field-for-field against erc-8301.md
                     (JimmyShi22/ERCs @ erc-agent-execution §AgentTask). Spec is a pre-filing draft —
                     re-confirm if it changes when it lands on ethereum/ERCs.

  PRECEDENCE — ERC-8263 anchor (value-fidelity type-2)
    8263/precedence  <digest> <ots_proof_url_or_file> [outcome_timestamp]
                     OTS digest → Bitcoin block → merkleroot cross-checked off a public
                     explorer (no node, no trust); strict block_time < outcome if given

  BOUNDED ACTIONS — ERC-8312 aggregate cap (Atlas-Protocol-AI/zero-human-loop)
    8312/cap-conservation  <rpc> <cursor_addr> <mandateId> <cap> [block]
                     reserved[mid] + confirmed[mid] ≤ cap, proven from STORAGE (eth_getProof vs
                     stateRoot, no trusted meter read) via recompute-storage-proof. The audit half
                     of the cursor; sound because the Security clause binds confirm/cancel to the reserver.

  DEFENSE STANDING — Layer 3 completeness bond (damonzwicker/scope-contestation)
    scope/bond-standing  <rpc> <bond_addr> <bondId> [as_of]
                     recompute(survival(bondId)) → standing = (not slashed ∧ not challenged);
                     bounty=amount, age=as_of−bondStart (Lindy strength). "which agent is good?"
                     recomputed from public bond state, not asserted.

  — 7 flow steps + value-fidelity + contest-verify + cap-conservation + Layer-3 standing —
EOF
    ;;

  8004/agent-id)
    # The ERC-8004 agentId per ERC-8299 (live erc-8299.md, PR #1810): a bytes32 registry-identity
    # anchor — the id the ERC-8004 registry ASSIGNS (Wizgob = 860), paired with the registry addr.
    # NOT a hash of any name. Canonical encoding of a uint256 registry id: bytes32(uint256(id)),
    # left-padded. (Encoding pin proposed for §8299; bytes32(uint256(id)) is the only sane mapping.)
    #   8004/agent-id <registryId> [expected_bytes32]
    id="${2:?need the ERC-8004 registry id (uint256), e.g. 860}"; exp="${3:-}"
    node="0x$(python3 -c "print(format(int('$id'), '064x'))")"
    echo "→ 8004/agent-id: agentId = bytes32(uint256($id))  (ERC-8004 registry identity, ERC-8299)"
    echo "──────────────────────────────────────────────────────────"
    echo "agentId: $node"
    if [ -n "$exp" ]; then
      if [ "$(echo "$node" | tr 'A-Z' 'a-z')" = "$(echo "$exp" | tr 'A-Z' 'a-z')" ]; then
        echo "✓ VERIFIED-GOOD — encodes to the committed agentId"
      else echo "✗ VERIFIED-BAD — bytes32(uint256($id))=$node ≠ claim $exp"; exit 1; fi
    fi
    ;;

  name/keccak-binding)
    # keccak256(utf8(label)) — a NAME→handle binding (the wyriwe-preimage leg for agentRef/
    # modelLabel/etc). NOT the ERC-8004 agentId (that's the registry id; see 8004/agent-id) and
    # NOT an ENS namehash (see ens/namehash). If used as identity, the derivation MUST be declared.
    #   name/keccak-binding <label> <expected_digest>
    ref="${2:?need a label/name}"; exp="${3:?need expected digest}"
    command -v cast >/dev/null || { echo "need foundry (cast)" >&2; exit 69; }
    echo "→ name/keccak-binding: keccak256(utf8(\"$ref\"))  (name→handle binding, NOT the 8004 agentId)"
    exec "$BIN/recompute-commitment" keccak "$exp" "$(cast from-utf8 "$ref")" ;;

  receiptos/receipt-hash)
    f="${2:?need a receipt .json file}"
    python3 - "$f" <<'PY'
import sys, json, hashlib
r = json.load(open(sys.argv[1]))
canon = lambda o: json.dumps(o, ensure_ascii=False, sort_keys=True, separators=(',', ':')).encode()
sha = lambda b: hashlib.sha256(b).hexdigest()
unsigned = {k: v for k, v in r.items() if k not in ('hashes', 'signature')}
decision = sha(canon(unsigned))
prev = (r.get('hashes') or {}).get('prev_receipt_sha256')
receipt = sha(f"{decision}|{prev or ''}".encode())
exp = (r.get('hashes') or {}).get('receipt_sha256')
print("→ receiptos/receipt-hash: receipt_sha256 = sha256(decision_sha256 ‖ prev)  [receiptos-mvp]")
print("─" * 45)
print("decision_sha256 (recomputed):", decision)
print("receipt_sha256  (recomputed):", receipt)
print("receipt_sha256  (published) :", exp)
ok = receipt == exp
print("✓ RECOMPUTED — receipt hash matches the published chain" if ok
      else "✗ MISMATCH — recomputed receipt hash ≠ published")
sys.exit(0 if ok else 1)
PY
    ;;

  8275/reputation)
    # ERC-8275 reputation is a RECOMMENDED, impl-defined SHAPE — there is NO canonical score to
    # verdict (the spec says so deliberately). So the recompute lives ONE LEVEL DOWN: this recipe
    # verdicts that the recomputable INPUTS reproduce, and shows the composite only as a VIEW.
    #   winRate = commit_gated_wins / (commit_gated_wins + commit_gated_losses)  [commit-gated outcomes]
    #   closedOutcomes = commit_gated_closed
    #   attestationCount / counterpartyDiversity -> per-entry schnorr-verify + distinct artifact_hash
    #     = the verify-proof leg (separate recipe), composed above this one.
    # reputation = winRate*min(closed,cap)/cap is f(inputs) — a lens, never a pass/fail.
    url="${2:-https://api.babyblueviper.com/ledger}"
    python3 - "$url" <<'PYEOF'
import sys, json, urllib.request
d = json.load(urllib.request.urlopen(sys.argv[1], timeout=15))
r = d['reputation_axis']; dv = r['derivation']; inp = r['inputs']
gw, gl, gc = dv['commit_gated_wins'], dv['commit_gated_losses'], dv['commit_gated_closed']
cap = inp['volumeCap']
print("-> 8275/reputation: assert the INPUTS reproduce; the score is a VIEW, not a verdict")
print("-" * 60)
print(f"commit-gated counts:  wins={gw} losses={gl} closed={gc}   volumeCap={cap}")
winRate = round(gw / (gw + gl), 4)
checks = [("winRate = gw/(gw+gl)", winRate, round(inp['winRate'], 4)),
          ("closedOutcomes",       gc,      dv['commit_gated_closed'])]
bad = 0
for name, got, pub in checks:
    ok = (abs(got - pub) < 5e-4) if isinstance(got, float) else (got == pub)
    print(f"  {name:22} recomputed {got}  vs published {pub}  {'OK' if ok else 'X'}")
    bad += 0 if ok else 1
rep_view = winRate * min(gc, cap) / cap
print(f"  reputation = f(inputs):  {rep_view:.4f}   [VIEW - impl-choice f, not a verdict; published {r['reputation']}]")
print("  attestationCount / counterpartyDiversity: recompute per-entry via verify-proof (schnorr + artifact_hash)")
if bad == 0:
    print("VERIFIED-GOOD - the recomputable INPUTS reproduce from public commit-gated counts (score stays a view)")
    sys.exit(0)
print(f"VERIFIED-BAD - {bad} input(s) do NOT reproduce from the published counts"); sys.exit(1)
PYEOF
    ;;

  wyriwe/raw)
    raw="${2:?need raw_input hex}"; exp="${3:?need expected raw_input_hash}"
    echo "→ wyriwe/raw: raw_input_hash = keccak256(raw_user_input)"
    exec "$BIN/recompute-commitment" keccak "$exp" "$raw" ;;

  wyriwe/pipeline)
    # ERC-8299 §46: sanitization_pipeline_hash = keccak256(sanitization_spec_cid_bytes ‖ raw_input_hash).
    # ASSUMPTION: cid_bytes = the UTF-8 bytes of the CID string. §46 writes "cid_bytes" without pinning
    # utf8(cid-string) vs the decoded multihash — flagged for the #1810 review; an impl using the
    # multihash bytes diverges silently. This recipe commits to utf8(cid).
    cid="${2:?need sanitization_spec_cid}"; rawhash="${3:?need raw_input_hash}"; exp="${4:?need expected}"
    command -v cast >/dev/null || { echo "need foundry (cast)" >&2; exit 69; }
    cidhex="$(cast from-utf8 "$cid")"
    packed="$(cast concat-hex "$cidhex" "$rawhash")"
    echo "→ wyriwe/pipeline: keccak256( utf8(\"$cid\") ‖ $rawhash )   [cid = utf8 string bytes — see §46 note]"
    exec "$BIN/recompute-commitment" keccak "$exp" "$packed" ;;

  scope/binding)
    root="${2:?need merkleRoot}"; n="${3:?need count}"; exp="${4:?need expected scopeRoot}"
    echo "→ scope/binding: bind(root,N) = keccak256(abi.encode(root, $n))"
    exec "$BIN/recompute-commitment" abi-keccak "$exp" "f(bytes32,uint256)" "$root" "$n" ;;

  scope/suite)
    ref="${2:-main}"
    exec "$BIN/recompute-repo" https://github.com/TMerlini/hack-ens-recovery "$ref" \
      "cd scope-contestation-demo/contracts && (ls lib/forge-std >/dev/null 2>&1 || git clone -q --depth 1 https://github.com/foundry-rs/forge-std lib/forge-std) && forge test" ;;

  8274/verify)
    rpc="${2:?need rpc-url (mainnet)}"; block="${3:?need block (pin, or latest)}"
    inh="${4:?need inputHash}"; outh="${5:?need outputHash}"
    meta="${6:?need metadata bytes (0x…)}"; proof="${7:?need proof bytes (0x…)}"
    echo "→ 8274/verify: WyriweProofVerifier(0xd8a0…18a09).verify(inputHash,outputHash,metadata,proof) == true"
    exec "$BIN/recompute-onchain" "$rpc" "$block" 0xd8a09d830b27697e1b24e8c9800e562d20318a09 \
      "verify(bytes32,bytes32,bytes,bytes)(bool)" true "$inh" "$outh" "$meta" "$proof" ;;

  8301/task-hash)
    stage="${2:?need stage}"; seq="${3:?need taskSeq}"; inh="${4:?need inputHash}"
    ts="${5:?need timestamp}"; exp_at="${6:?need expiresAt}"; run="${7:?need workflowRunId}"
    expected="${8:?need expected taskHash}"; prev="${9:-0x}"
    command -v cast >/dev/null || { echo "need foundry (cast)" >&2; exit 69; }
    # inner: keccak256(abi.encodePacked(prevReplyHashes)) — packed = concat of the bytes32 elems (0x = empty / initial task)
    inner="$(cast keccak "$prev")"
    echo "→ 8301/task-hash: keccak256(abi.encode(stage,taskSeq,inputHash,timestamp,expiresAt,keccak(prevReplyHashes),workflowRunId))"
    echo "  prevReplyHashes hash = $inner"
    exec "$BIN/recompute-commitment" abi-keccak "$expected" \
      "f(uint8,uint256,bytes32,uint256,uint256,bytes32,bytes32)" \
      "$stage" "$seq" "$inh" "$ts" "$exp_at" "$inner" "$run" ;;

  8263/precedence)
    digest="${2:?need OTS digest (event_id stamped)}"; proof="${3:?need .ots proof url or file}"
    outcome="${4:-}"
    python3 - "$digest" "$proof" "$outcome" <<'PY'
import sys, os, re, json, shutil, subprocess, tempfile, urllib.request
def unverifiable(msg): print("⊘ UNVERIFIABLE —", msg); sys.exit(2)   # couldn't check ≠ verified-bad
digest, proof, outcome = sys.argv[1], sys.argv[2], (sys.argv[3] or None)
ots = shutil.which("ots") or os.path.expanduser("~/Library/Python/3.14/bin/ots")
if not os.path.exists(ots) and not shutil.which("ots"):
    unverifiable("OpenTimestamps client not installed (pip install opentimestamps-client)")
# resolve proof → local file
pf = proof
if proof.startswith("http"):
    pf = tempfile.mktemp(suffix=".ots")
    try: urllib.request.urlretrieve(proof, pf)
    except Exception as e: unverifiable(f"could not fetch the .ots proof: {e}")
# OTS resolves the proof to a Bitcoin block + merkleroot (no local node)
r = subprocess.run([ots, "--no-bitcoin", "verify", "-d", digest, pf], capture_output=True, text=True)
m = re.search(r"Bitcoin block (\d+) has merkleroot ([0-9a-fA-F]+)", r.stdout + r.stderr)
if not m:
    unverifiable("OTS proof not yet anchored to a Bitcoin block (pending, or node unreachable):\n" + (r.stdout + r.stderr)[-300:])
block, ots_root = int(m.group(1)), m.group(2).lower()
# cross-check the merkleroot off a public explorer (no node, no trust in the ledger)
try:
    h = urllib.request.urlopen(f"https://blockstream.info/api/block-height/{block}", timeout=15).read().decode()
    b = json.load(urllib.request.urlopen(f"https://blockstream.info/api/block/{h}", timeout=15))
except Exception as e:
    unverifiable(f"explorer unreachable — can't cross-check the merkleroot: {e}")
exp_root, block_time = b["merkle_root"].lower(), b["timestamp"]
print(f"→ 8263/precedence: OTS digest → Bitcoin block {block}, merkleroot cross-checked off blockstream")
print("─" * 56)
print(f"OTS merkleroot:      {ots_root}")
print(f"explorer merkleroot: {exp_root}  (block {block})")
print(f"block_time:          {block_time}")
if ots_root != exp_root:
    print("✗ VERIFIED-BAD — OTS merkleroot ≠ explorer merkleroot (anchor not confirmed)"); sys.exit(1)
if outcome:
    strict = block_time < int(outcome)
    print(f"strict precedence:   {block_time} < {outcome}  →  {strict}")
    if not strict:
        print("✗ VERIFIED-BAD — anchor not strictly before the outcome"); sys.exit(1)
    print("✓ VERIFIED-GOOD — anchor Bitcoin-confirmed AND strictly precedes the outcome")
else:
    print("✓ VERIFIED-GOOD — anchor Bitcoin-confirmed (merkleroot matches explorer); pass an outcome_ts for the strict < check")
PY
    ;;

  scope/bond-standing)
    # Layer 3 (damonzwicker/scope-contestation, ICompletenessBond): recompute an agent's
    # completeness STANDING from the public bond state — survival(bondId) — never from an
    # asserted score. standing = (not slashed) and (not challenged): the bond was never
    # falsified by a material-omission proof. bounty + age are the Lindy strength signal.
    rpc="${2:?need rpc-url}"; bond="${3:?need bond contract addr}"
    bondId="${4:?need bondId (bytes32)}"; asof="${5:-}"
    python3 - "$rpc" "$bond" "$bondId" "$asof" <<'PY'
import sys, subprocess, time
rpc, bond, bondId, asof = sys.argv[1], sys.argv[2], sys.argv[3], (sys.argv[4] or None)
# exact ABI from ICompletenessBond.sol survival(bytes32):
sig = "survival(bytes32)(uint256,uint64,uint64,uint64,bool,bool)"
r = subprocess.run(["cast","call",bond,sig,bondId,"--rpc-url",rpc],
                   capture_output=True, text=True)
if r.returncode != 0:
    print("⊘ UNVERIFIABLE — survival() call failed (bond not deployed / RPC unreachable):", (r.stderr or r.stdout).strip()[:160]); sys.exit(2)
v = r.stdout.split()
amount, bondStart, termEnd, resolvedAt = int(v[0]), int(v[1]), int(v[2]), int(v[3])
slashed, challenged = v[4].lower()=="true", v[5].lower()=="true"
# the recompute (Point: standing-as-survival, not asserted):
standing = (not slashed) and (not challenged)
state = "live" if resolvedAt==0 else ("survived (reclaimed)" if not slashed else "slashed")
now = int(asof) if asof else int(time.time())
# Damon's canonical "age under open bounty": freezes at resolvedAt — a dead/reclaimed
# bond stops accruing standing. age = min(now, resolvedAt or now) − bondStart.
end = resolvedAt if resolvedAt != 0 else now
age = end - bondStart
print(f"→ scope/bond-standing: recompute(survival({bondId[:12]}…)) — Layer 3 completeness bond")
print("─"*58)
print(f"bounty (amount):     {amount}  (permanent bounty record — preserved in every state, CompletenessBond ≥1922985)")
print(f"age under bounty:    {age}s  (termEnd in {termEnd-now}s)")
print(f"state:               {state}")
print(f"slashed / challenged: {slashed} / {challenged}")
print(f"STANDING:            {standing}")
print("✓ STANDING — recomputed from public bond state: unslashed, unchallenged "
      "(bounty×age = Lindy strength)" if standing else
      "✗ NOT STANDING — bond falsified (slashed or successfully challenged)")
sys.exit(0 if standing else 1)
PY
    ;;

  scope/value-fidelity)
    # Type-2 (off-chain resolution): recompute the resolutionRoot from a's (sourceId,value)
    # pairs and compare to the committed root — guard 5 / Damon's ResolutionCommitment.
    #   leaf = keccak256(abi.encode(bytes32 sourceId, uint8 option))   [votes sorted by sourceId asc]
    #   resolutionRoot = keccak256(abi.encode(bytes32[] leaves))
    committed="${2:?need committed resolutionRoot (or - to just compute)}"; shift 2
    python3 - "$committed" "$@" <<'PY'
import sys, subprocess
def cast(*a): return subprocess.run(["cast", *map(str, a)], capture_output=True, text=True).stdout.strip()
committed = sys.argv[1]
pairs = [p.split(":") for p in sys.argv[2:]]
if not pairs: print("need <sourceId>:<option> pairs"); sys.exit(64)
pairs.sort(key=lambda p: int(p[0], 16))                 # contract sorts by sourceId ascending
leaves = [cast("keccak", cast("abi-encode", "f(bytes32,uint8)", sid, opt)) for sid, opt in pairs]
root = cast("keccak", cast("abi-encode", "f(bytes32[])", "[" + ",".join(leaves) + "]"))
print("→ scope/value-fidelity: recompute resolutionRoot (type-2, guard 5)")
print("─"*58)
for sid, opt in pairs: print(f"  {sid[:14]}… : {opt}")
print(f"recomputed root: {root}")
if committed and committed != "-":
    ok = root.lower() == committed.lower()
    print(f"committed root:  {committed}")
    print("✓ VALUE-FIDELITY HOLDS — a reproduces the committed resolution" if ok
          else "✗ MISMATCH — a's values do NOT reproduce the committed resolution (adversarial-a / drift)")
    sys.exit(0 if ok else 1)
PY
    ;;

  scope/value-fidelity-onchain)
    # Type-1 (chain-native): recompute each source's value off the committed reader at the
    # pinned pre-outcome block — guard 5 via ChainNativeResolution. reader.valueAt(sourceId, blockPin).
    rpc="${2:?need rpc-url}"; reader="${3:?need reader addr}"; blockPin="${4:?need blockPin}"; shift 4
    python3 - "$rpc" "$reader" "$blockPin" "$@" <<'PY'
import sys, subprocess
rpc, reader, pin = sys.argv[1], sys.argv[2], sys.argv[3]
pairs = [p.split(":") for p in sys.argv[4:]]
print(f"→ scope/value-fidelity-onchain: recompute valueAt(sourceId, {pin}) (type-1, guard 5)")
print("─"*58)
bad = 0; unver = 0
for sid, opt in pairs:
    r = subprocess.run(["cast","call",reader,"valueAt(bytes32,uint256)(uint8)",sid,pin,"--rpc-url",rpc],
                       capture_output=True, text=True)
    out = r.stdout.strip().split()
    if r.returncode != 0 or not out:
        print(f"  {sid[:14]}… ⊘ unreadable: {(r.stderr or r.stdout).strip()[:70]}"); unver += 1; continue
    got = out[0]; ok = got == opt
    print(f"  {sid[:14]}… claimed {opt} | chain {got}  {'✓' if ok else '✗'}")
    bad += 0 if ok else 1
if unver:
    print(f"⊘ UNVERIFIABLE — {unver} source(s) could not be read (RPC/reader unreachable); can't conclude"); sys.exit(2)
print("✓ VERIFIED-GOOD — every source matches the chain at blockPin" if bad==0
      else f"✗ VERIFIED-BAD — {bad} source(s) do NOT match the chain reading")
sys.exit(1 if bad else 0)
PY
    ;;

  scope/contest-verify)
    # The four-guard + guard-7 contest() SEPARATION verdict, recomputed: separated = w(a) != w(b),
    # b = a ++ [X], via the real MajorityClassifier plurality/quorum rules (NO_QUORUM on tie or
    # below-quorum). This is the materiality core the completeness bond slashes on. The guards
    # compose existing legs: value fidelity of `a` and of the contested X route through
    # scope/value-fidelity[-onchain] (guard 5 / guard 7); a TYPE-2 contest's guard-7 returns false
    # → those recipes report UNVERIFIABLE (defer to the source-auth leg) — that's the tri-state span.
    #   scope/contest-verify <quorumBps> <a-options-csv> <X-option> [expected_separated:true|false]
    # options are the classifier's uint8 codes (harness: WIN=1, LOSS=2, DRAW=3).
    q="${2:?need quorumBps}"; aopts="${3:?need a-options csv e.g. 1,1,1,3,3,3,2}"; xopt="${4:?need X option}"; exp="${5:-}"
    python3 - "$q" "$aopts" "$xopt" "$exp" <<'PY'
import sys
from collections import Counter
q = int(sys.argv[1]); a = [int(x) for x in sys.argv[2].split(",") if x != ""]
x = int(sys.argv[3]); exp = sys.argv[4]
def plurality(opts):
    # mirrors MajorityClassifier._plurality: count per option, scan options ascending,
    # NO_QUORUM (None) on empty / tie-at-max / below-quorum, else the sole plurality winner.
    if not opts: return None
    c = Counter(opts); total = len(opts); best = 0; bestC = 0; tie = False
    for o in sorted(c):
        if c[o] > bestC: bestC, best, tie = c[o], o, False
        elif c[o] == bestC and bestC > 0: tie = True
    if tie: return None
    if bestC * 10000 < total * q: return None
    return best
wa, wb = plurality(a), plurality(a + [x])
separated = wa != wb
nm = lambda w: "NO_QUORUM" if w is None else str(w)
print("→ scope/contest-verify: separated = w(a) != w(b),  b = a ++ [X]  (MajorityClassifier rules)")
print("─"*58)
print(f"quorum:            {q} bps")
print(f"w(a)  over {a}: {nm(wa)}")
print(f"w(b)  over {a+[x]}: {nm(wb)}   (X = {x})")
print(f"separated:         {str(separated).lower()}   → X is {'MATERIAL (slash)' if separated else 'immaterial (bond stands)'}")
print("  guards 5/7 (value-fidelity of a + of X) compose scope/value-fidelity[-onchain]; type-2 guard-7 → UNVERIFIABLE (defers)")
if exp:
    want = exp.lower() in ("true", "1", "yes")
    ok = (separated == want)
    print(f"committed verdict: {str(want).lower()}")
    print("✓ VERIFIED-GOOD — recomputed separation matches the committed contest verdict" if ok
          else "✗ VERIFIED-BAD — recomputed separation ≠ committed (unsound contest claim)")
    sys.exit(0 if ok else 1)
PY
    ;;

  ens/namehash)
    # EIP-137 namehash — the node ENS actually resolves. DISTINCT from a flat keccak256(utf8(name)):
    # namehash recurses node = keccak(parentNode ‖ keccak(label)) right-to-left over the labels.
    # The identity an ENS-native stack keys on — cf. the 8004/agent-id "string-hash vs namehash"
    # question (keccak("agent.eth") != namehash("agent.eth")).
    #   ens/namehash <name> [expected_node]
    name="${2:?need an ENS name, e.g. agent.eth}"; exp="${3:-}"
    node="$(cast namehash "$name" 2>/dev/null)"
    [ -z "$node" ] && { echo "⊘ UNVERIFIABLE — need foundry (cast) for namehash"; exit 2; }
    echo "→ ens/namehash: EIP-137 node = keccak(parent ‖ keccak(label)) over \"$name\""
    echo "──────────────────────────────────────────────────────────"
    echo "namehash: $node"
    if [ -n "$exp" ]; then
      if [ "$(echo "$node" | tr 'A-Z' 'a-z')" = "$(echo "$exp" | tr 'A-Z' 'a-z')" ]; then
        echo "✓ VERIFIED-GOOD — namehash matches the committed node"
      else
        echo "✗ VERIFIED-BAD — namehash $node ≠ claim $exp"; exit 1
      fi
    fi
    ;;

  8312/cap-conservation)
    # ERC-8312 aggregate cap: prove reserved[mandateId] + confirmed[mandateId] <= cap from STORAGE
    # — eth_getProof Merkle-inclusion vs the block's stateRoot, NOT a trusted meter read — composing
    # recompute-storage-proof. The audit half of the cursor (enforce = ordered write; audit =
    # recompute). reserved = mapping @ slot 0, confirmed @ slot 1 (StatefulBound layout). Re-derives
    # to a SOUND verdict because the ERC-8312 Security clause binds confirm/cancel to the reserver
    # (finding 1) — without it a third party frees in-flight room and the trajectory is forgeable.
    #   8312/cap-conservation <rpc> <cursor_addr> <mandateId> <cap> [block]
    rpc="${2:?need rpc}"; sb="${3:?need cursor addr}"; mid="${4:?need mandateId}"; cap="${5:?need cap}"; blk="${6:-latest}"
    python3 - "$BIN" "$rpc" "$sb" "$mid" "$cap" "$blk" <<'PY'
import sys, subprocess, re, time
BIN, rpc, sb, mid, cap, blk = sys.argv[1:7]; cap = int(cap)
def sh(*a): return subprocess.run(a, capture_output=True, text=True)
def slot(base): return sh("cast", "index", "bytes32", mid, str(base)).stdout.strip()
s0, s1 = slot(0), slot(1)
def prove(block, slot_hex):
    r = sh(BIN + "/recompute-storage-proof", rpc, str(block), sb, slot_hex)
    if r.returncode == 2: return None
    m = re.search(r"slot value:\s*(0x[0-9a-fA-F]+)", r.stdout)
    return int(m.group(1), 16) if m else None
# Prove BOTH slots at ONE block (same stateRoot). Keyless public RPCs often serve eth_getProof
# only near the tip (narrow window) + load-balance across desynced backends, so a tip pin races
# the head — re-resolve "latest" and retry both slots together. An explicit block is tried once.
reserved = confirmed = pin = None
for _ in range(6):
    if blk == "latest":
        r = sh("cast", "block-number", "--rpc-url", rpc)
        if r.returncode != 0: time.sleep(0.6); continue
        pin = r.stdout.strip()
    else:
        pin = blk
    reserved, confirmed = prove(pin, s0), prove(pin, s1)
    if reserved is not None and confirmed is not None: break
    if blk != "latest": break          # explicit block: window error is terminal
    time.sleep(0.6)
print(f"→ 8312/cap-conservation: reserved+confirmed ≤ cap, proven vs stateRoot @ block {pin}")
print("─"*58)
if reserved is None or confirmed is None:
    print("⊘ UNVERIFIABLE — could not prove a slot (an old block needs an archive RPC with a wide getProof window)"); sys.exit(2)
committed = reserved + confirmed
print(f"reserved  (slot 0): {reserved}")
print(f"confirmed (slot 1): {confirmed}")
print(f"committed:          {committed}    cap: {cap}")
if committed <= cap:
    print(f"✓ VERIFIED-GOOD — aggregate {committed} ≤ cap {cap}, proven from storage (no trusted meter read)")
    sys.exit(0)
print(f"✗ VERIFIED-BAD — aggregate {committed} > cap {cap}: the cap was exceeded in committed state"); sys.exit(1)
PY
    ;;

  *)
    echo "unknown recipe: $recipe  (try: recompute-step list)" >&2; exit 64 ;;
esac
